-- main/main.script — bootstrap: acquire input focus for the GO (the gui
-- component on this GO receives touch input through it) and kick the
-- resume-on-boot check. All screen logic lives in main/game.gui_script;
-- the sim instance lives in the shared module main/game.lua.

local game = require "main.game"

function init(self)
  msg.post(".", "acquire_input_focus")
  -- Idempotent: whichever component initializes first performs the restore.
  game.resume()
end
